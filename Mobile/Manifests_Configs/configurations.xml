	  <add type="audio" oid="17036027" id="61370263" /><!--Я идиот, убейте меня кто-нибудь-->
	
    <add type="video" oid="10946144" id="103210810" /><!--Спарта Онотоле-->
    <add type="video" oid="17036027" id="103316885" /><!--ОНОТОЛЕ ОТАКЕ УГ-->
  </wall>
  
<!--===============ОБСУЖДЕНИЯ====================
enabled                     значение флажка "Обсуждения" по умолчанию
create_new                  значение флажка "Обсуждения\Создавать новые" по умолчанию
answer_exist                значение флажка "Обсуждения\Пячить существующие" по умолчанию
create_time_delay           временная задержка на создание новых обсуждений в миллисекундах
answer_time_delay           временная задержка на добавления ответов в УГ-обсуждения в миллисекундах
title_length                длинна названий новых обсуждения
post_length                 длинна сабжей новых обсуждения
answer_length               длинна ответов в УГ-бсуждения
grab_max_count              максимальное количество обсуждений, которые будут сграблены
no_attack_today_created     не пячить созданные сегодня(по гринвичу) обсуждения
recognize_by_key            не пячить обсуждения содержащие спецключ
random_answer_start         начинать попячивание УГ-обсуждений со случайного обсуждения(TRUE) или с первого(FALSE)
-->
  <topics enabled="true"
          create_new="true"
          answer_exist="true"
          create_time_delay="2000"
          answer_time_delay="2000"
          title_length="300"
          post_length="1000"
          answer_length="1000"
          grab_max_count="300"
          no_attack_today_created="false" 
          recognize_by_key="true" 
          random_answer_start="false" 
          />
  
<!--==================АЛЬБОМЫ===================
enabled                     значение флажка "Альбомы" по умолчанию
create_new                  значение флажка "Альбомы\Создавать новые" по умолчанию
photos_upload_to_exist      значение флажка "Альбомы\Пячить существующие" по умолчанию
desc_length                 длина описания новых альбомов
create_time_delay           временная задержка на создание новых альбомов в миллисекундах
photos_upload_time_delay    временная задержка на загрузку фото в УГ-альбомы в миллисекундах
grab_max_count              максимальное количество альбомов, которые будут сграблены
photos_always_upload        каждый раз загружать фото
no_attack_today_created     не пячить созданные сегодня(по гринвичу) альбомы
recognize_by_key            не пячить альбомы содержащие спецключ
-->
  <albums enabled="true"
          create_new="true"
          photos_upload_to_exist="true"
          create_time_delay="20000"
          desc_length="1000"
          photos_upload_time_delay="200"
          grab_max_count="300"
          photos_always_upload="false" 
          no_attack_today_created="true"
          recognize_by_key="true" >
    
