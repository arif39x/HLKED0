    <add src="source\kot_01.jpg" />
    <add src="source\kot_02.jpg" />
    <add src="source\kot_03.jpg" />
    <add src="source\leonide_01.jpg" />
    <add src="source\onotole_01.jpg" />
    <add src="source\onotole_02.jpg" />
    <add src="source\shmele_01.jpg" />
  </albums>


  
<!--========================АУДИО========================
enabled             значение флажка "Аудио" по умолчанию
rename              значение флажка "Аудио\Лучепонос в названии" по умолчанию
time_delay          временная задержка на загрузку аудио в миллисекундах
performer_length    длина исполнителя песни
title_length        длина на звания песни
-->
  <audio enabled="true"
         rename="true"
         time_delay="100"
         performer_length="100"
         title_length="100" >
    <!--сюда добавлять аудио для загрузки в формате <add src="ПУТЬ_К_ФАЙЛУ"/>-->
    <add src="source\audio_01.mp3" />
