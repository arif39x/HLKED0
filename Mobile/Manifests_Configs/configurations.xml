<configurations>

<!--===============ОБЩИЕ=======================
library           файл словаря лучепеноса
proxy             прокси-сервер в формате IP:PORT
random_case       случайный регистр лучепеноса
ascii_img         вставлять ASCII картинки(многострочные сообщения) в понос
extra_lines       разделять фразы поноса переходами строк
full_log          выводить списки УГ-обсуждений, УГ-альбомов и УГ-видео в лог при сканировании
auto_delays       автоувеличение временной задержки при сообщениях о быстрой отправке
captcha_timeout   время, после которого капча будет автоматически игнорирована, в секундах
-->
  <general library="source\up4k_lib.txt"
           proxy=""
           random_case="true"
           ascii_img="true"
           extra_lines="true" 
           full_log="true" 
           auto_delays="true"
           captcha_timeout="60"
           />
  
<!--=============СТЕНА=======================
enabled       значение флажка "Стена" по умолчанию
msg_length    длина поноса
time_delay    временная задержка в милисекундах
lucheponos    постить понос
post_audio    постить аудио [[audioХХХХХ_ХХХХХ]]
post_video    постить видео [[videoХХХХХ_ХХХХХ]]
post_graff    постить граффити
-->
  <wall enabled="true"
        msg_length="1000"
        time_delay="400"
        lucheponos="true"
        post_audio="true"
        post_video="false"
        post_graff="false" >
		
    <add type="graff" src="source\balet_01.jpg" />
    <add type="graff" src="source\balet_02.jpg" />
    <add type="graff" src="source\chake_01.jpg" />
    <add type="graff" src="source\goose_01.jpg" />
    <add type="graff" src="source\kot_01.jpg" />
    <add type="graff" src="source\kot_02.jpg" />
    <add type="graff" src="source\kot_03.jpg" />
    <add type="graff" src="source\leonide_01.jpg" />
    <add type="graff" src="source\onotole_01.jpg" />
    <add type="graff" src="source\onotole_02.jpg" />
    <add type="graff" src="source\shmele_01.jpg" />
    
    <add type="audio" oid="11385094" id="62808332" /><!--марш военов упчк-->
