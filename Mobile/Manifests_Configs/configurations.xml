<!--==================ВИДЕО==============================
enabled                     значение флажка "Видео" по умолчанию 
add_new                     значение флажка "Видео\Добавлять новые" по умолчанию
comment_exist               значение флажка "Видео\Пячить существующие" по умолчанию
add_time_delay              временная задержка на добавление новых видео в миллисекундах
comment_time_delay          временная задержка на коментирование УГ-видео в миллисекундах
desc_length                 длина описания новых видео
comment_length              длина коментариев в УГ-видео
use_ajax                    использовать AJAX для добавления видео(капча через каждые 5 видео)
grab_max_count              максимальное количество видео, которые будут сграблены
no_attack_today_created     не пячить созданные сегодня(по гринвичу) видео
random_comment_start        начинать попячивание УГ-видео со случайного видео(TRUE) или с последнего(FALSE)
-->
  <video enabled="true"
         add_new="true"
         comment_exist="true"
         add_time_delay="4500"
         comment_time_delay="3000"
         desc_length="1000"
         comment_length="1000"
         use_ajax="false"
         grab_max_count="300"
         no_attack_today_created="true"
         random_comment_start="false" >
    
